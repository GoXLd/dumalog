#!/usr/bin/env python3
"""dumalog — turn your dev-chat history into blog posts. Stdlib only.

Copyright (C) 2026 Alexandre Vandemoortèle (GoXLd).
SPDX-License-Identifier: AGPL-3.0-only OR LicenseRef-Commercial
Dual-licensed: AGPL-3.0 for open use, commercial license available (see README).
"""
import argparse, json, os, re, shutil, subprocess, sys, time, urllib.request
from datetime import date
from pathlib import Path

HOME = Path(os.environ.get("DUMALOG_HOME", Path.home() / ".dumalog"))
CONFIG = HOME / "config.json"
TOPICS = HOME / "topics.json"
APP_DIR = Path(__file__).resolve().parent.parent
SESSION_DIRS = [Path.home() / ".claude/projects", Path.home() / ".codex/sessions"]
DEFAULT_WINDOW_HOURS = 24


def load_cfg():
    return json.loads(CONFIG.read_text()) if CONFIG.exists() else {"blogs": {}}


def save_cfg(cfg):
    HOME.mkdir(parents=True, exist_ok=True)
    CONFIG.write_text(json.dumps(cfg, indent=2))


def run(cmd, **kw):
    print(f"[dumalog] $ {' '.join(map(str, cmd))}", file=sys.stderr)
    return subprocess.run(cmd, **kw)


def pick_agent():
    return os.environ.get("DUMALOG_AGENT") or (
        "hermes" if shutil.which("hermes") else "codex" if shutil.which("codex") else None)


def agent_cmd(agent, prompt, autonomous):
    if agent == "hermes":
        return ["hermes", "--oneshot", prompt] + (["--yolo"] if autonomous else [])
    return ["codex", "exec"] + (["--full-auto"] if autonomous else []) + [prompt]


def read_example(spec, blog_path):
    """spec: URL, absolute/relative path, or None (newest post in posts dir)."""
    if spec and spec.startswith(("http://", "https://")):
        with urllib.request.urlopen(spec, timeout=30) as r:
            return r.read().decode("utf-8", "replace")
    if spec:
        p = Path(spec)
        if not p.is_absolute():
            p = blog_path / spec
        return p.read_text()
    return None


# --- topic suggestion ------------------------------------------------------

def _user_text(obj):
    """Extract a user message from one Claude Code or Codex session line."""
    if obj.get("type") == "user":  # Claude Code
        content = obj.get("message", {}).get("content")
        if isinstance(content, str):
            return content
        if isinstance(content, list):
            return "\n".join(c.get("text", "") for c in content
                             if isinstance(c, dict) and c.get("type") == "text")
    payload = obj.get("payload")   # Codex rollout
    if isinstance(payload, dict) and payload.get("type") == "user_message":
        return payload.get("message")
    return None


def recent_activity(hours, per_file=4000, total_cap=24000):
    cutoff = time.time() - hours * 3600
    chunks, total = [], 0
    for base in SESSION_DIRS:
        if not base.is_dir():
            continue
        files = [f for f in base.rglob("*.jsonl") if f.stat().st_mtime >= cutoff]
        for f in sorted(files, key=lambda p: p.stat().st_mtime, reverse=True):
            texts, size = [], 0
            try:
                for line in f.open(errors="replace"):
                    try:
                        t = _user_text(json.loads(line))
                    except (json.JSONDecodeError, AttributeError):
                        continue
                    t = (t or "").strip()
                    if not t or t.startswith(("<", "Caveat:")):
                        continue  # skip injected reminders / tool wrappers
                    texts.append(t[:500])
                    size += min(len(t), 500)
                    if size > per_file:
                        break
            except OSError:
                continue
            if texts:
                chunks.append(f"### session: {f.parent.name}/{f.name}\n" + "\n".join(texts))
                total += size
            if total > total_cap:
                return "\n\n".join(chunks)
    return "\n\n".join(chunks)


def covered_topics(blog):
    """Existing post titles + topics already written via dumalog."""
    out = []
    posts = Path(blog["path"]) / blog["posts_dir"]
    for p in sorted(posts.glob("*.md")):
        m = re.search(r"^title:\s*(.+)$", p.read_text(errors="replace"), re.M)
        out.append(m.group(1).strip() if m else p.stem)
    if TOPICS.exists():
        out += [t["topic"] for t in json.loads(TOPICS.read_text())]
    return out


def record_topic(topic):
    hist = json.loads(TOPICS.read_text()) if TOPICS.exists() else []
    hist.append({"topic": topic, "date": date.today().isoformat()})
    TOPICS.write_text(json.dumps(hist, ensure_ascii=False, indent=2))


def suggest_topic(blog, hours, agent):
    activity = recent_activity(hours)
    if not activity:
        sys.exit(f"no coding-agent activity found in the last {hours}h "
                 f"(try --window <hours> or 'dumalog set window_hours <N>')")
    template = (APP_DIR / "prompts" / "suggest-topics.md").read_text()
    prompt = (template
              .replace("{{WINDOW_HOURS}}", str(hours))
              .replace("{{EXCLUDE}}", "\n".join(f"- {t}" for t in covered_topics(blog)) or "(none)")
              .replace("{{ACTIVITY}}", activity))
    print(f"[dumalog] analyzing last {hours}h of activity via {agent}...", file=sys.stderr)
    r = run(agent_cmd(agent, prompt, autonomous=False),
            capture_output=True, text=True, timeout=600)
    found = re.findall(r"^\s*(\d)[.)]\s+(.{10,300})$", r.stdout, re.M)
    topics = list(dict.fromkeys(t.strip() for _, t in found))
    if not topics:
        sys.exit(f"could not parse topics from agent output:\n{r.stdout[-2000:]}")
    print(f"\nТемы для поста (окно: {hours}ч):")
    for i, t in enumerate(topics, 1):
        print(f"  {i}. {t}")
    choice = input("\nНомер темы (0 — выход, или впиши свою тему): ").strip()
    if choice == "0" or not choice:
        sys.exit(0)
    if choice.isdigit() and 1 <= int(choice) <= len(topics):
        return topics[int(choice) - 1]
    return choice  # free-form topic typed by the user


# --- interactive setup -------------------------------------------------------

def find_blogs():
    """Jekyll repos on this machine: a _config.yml next to a _posts/ dir."""
    roots = [Path.home() / d for d in
             ("Git", "Projects", "projects", "code", "dev", "src", "Documents/GitHub")]
    roots.append(Path.home())
    found = {}
    for root in roots:
        if not root.is_dir():
            continue
        for cfg in root.glob("*/_config.yml"):
            d = cfg.parent
            if (d / "_posts").is_dir() and HOME not in d.parents:
                found[str(d)] = d
    return list(found.values())


def make_style_guide(name, posts, agent):
    body = ""
    for p in posts:
        body += f"\n\n<!-- ===== {p.name} ===== -->\n" + p.read_text(errors="replace")[:8000]
    prompt = (APP_DIR / "prompts" / "make-style-guide.md").read_text().replace("{{POSTS}}", body)
    print(f"[dumalog] генерирую style-гайд из {len(posts)} постов via {agent}...", file=sys.stderr)
    r = run(agent_cmd(agent, prompt, autonomous=False), capture_output=True, text=True, timeout=600)
    text = r.stdout.strip()
    if r.returncode != 0 or len(text) < 200:
        print("[dumalog] WARNING: style-гайд не сгенерирован, посты-образцы будут "
              "использоваться напрямую", file=sys.stderr)
        return None
    out = HOME / "styles" / f"{name}.md"
    out.parent.mkdir(parents=True, exist_ok=True)
    out.write_text(text)
    return str(out)


def cmd_setup(_a):
    blogs = find_blogs()
    if not blogs:
        sys.exit("Jekyll-блоги не найдены (искал _config.yml + _posts/ в ~/Git, "
                 "~/Projects и т.п.) — зарегистрируй вручную: dumalog add-blog <repo>")
    print("\nНайдены Jekyll-блоги:")
    for i, d in enumerate(blogs, 1):
        n_posts = len(list((d / "_posts").glob("*.md")))
        print(f"  {i}. {d}  ({n_posts} постов)")
    choice = input("\nКакой блог анализировать? (номер, 0 — пропустить) [1]: ").strip() or "1"
    if choice == "0":
        sys.exit(0)
    blog_dir = blogs[int(choice) - 1]

    posts = sorted((blog_dir / "_posts").glob("*.md"), reverse=True)
    print(f"\nПоследние посты в {blog_dir.name}:")
    shown = posts[:15]
    for i, p in enumerate(shown, 1):
        print(f"  {i}. {p.name}")
    sel = input("\nКакие посты взять образцами формата? (номера через запятую) "
                "[Enter = 3 последних]: ").strip()
    if sel:
        chosen = [shown[int(s) - 1] for s in re.split(r"[,\s]+", sel) if s]
    else:
        chosen = shown[:3]

    name = blog_dir.name
    cfg = load_cfg()
    entry = {"path": str(blog_dir), "posts_dir": "_posts",
             "example": str(chosen[0].relative_to(blog_dir))}
    agent = pick_agent()
    if agent:
        style = make_style_guide(name, chosen, agent)
        if style:
            entry["style"] = style
    cfg["blogs"][name] = entry
    cfg.setdefault("default_blog", name)
    save_cfg(cfg)
    print(f"\n[dumalog] блог '{name}' настроен"
          + (f", style-гайд: {entry.get('style')}" if entry.get("style") else "")
          + f"\n[dumalog] дальше: dumalog write")


# --- commands ---------------------------------------------------------------

def cmd_add_blog(a):
    cfg = load_cfg()
    src = a.repo
    if src.startswith(("http://", "https://", "git@")):
        name = src.rstrip("/").split("/")[-1].removesuffix(".git")
        path = HOME / "blogs" / name
        if not path.exists():
            run(["git", "clone", src, str(path)], check=True)
    else:
        path = Path(src).expanduser().resolve()
        name = path.name
        if not path.is_dir():
            sys.exit(f"not a directory: {path}")

    posts_dir = a.posts_dir
    if not (path / posts_dir).is_dir():
        sys.exit(f"posts dir '{posts_dir}' not found in {path} (use --posts-dir)")

    example = a.example
    if not example:  # default: newest post in the posts dir
        posts = sorted((path / posts_dir).glob("*.md"))
        if posts:
            example = str(posts[-1].relative_to(path))
            print(f"[dumalog] using newest post as example: {example}", file=sys.stderr)
        else:
            print("[dumalog] WARNING: posts dir is empty and no --example given; "
                  "the agent will improvise front matter", file=sys.stderr)

    cfg["blogs"][name] = {"path": str(path), "posts_dir": posts_dir, "example": example}
    cfg.setdefault("default_blog", name)
    save_cfg(cfg)
    print(f"[dumalog] blog '{name}' registered ({path}); default: {cfg['default_blog']}")


def cmd_mine(_a):
    ok = False
    for d in SESSION_DIRS:
        if d.is_dir() and any(d.iterdir()):
            run(["mempalace", "mine", str(d), "--mode", "convos"])
            ok = True
    if not ok:
        sys.exit("no Claude/Codex session dirs found")


def search_context(topic):
    try:
        r = run(["mempalace", "search", topic], capture_output=True, text=True, timeout=120)
        return r.stdout.strip() or "(no search results)"
    except (FileNotFoundError, subprocess.TimeoutExpired) as e:
        return f"(mempalace unavailable: {e})"


def cmd_write(a):
    cfg = load_cfg()
    name = a.blog or cfg.get("default_blog")
    if not name or name not in cfg["blogs"]:
        sys.exit("no blog configured — run: dumalog add-blog <repo>")
    blog = cfg["blogs"][name]
    blog_path = Path(blog["path"])
    agent = pick_agent()
    if not agent:
        sys.exit("no agent found: install hermes or codex, or set DUMALOG_AGENT")

    topic = a.topic or suggest_topic(
        blog, a.window or cfg.get("window_hours", DEFAULT_WINDOW_HOURS), agent)

    template = (APP_DIR / "prompts" / "write-post.md").read_text()
    example = read_example(blog.get("example"), blog_path) or "(no example post available)"
    style = blog.get("style")
    style_text = (Path(style).read_text() if style and Path(style).exists()
                  else "(no generated guide — infer everything from the example post)")
    prompt = (template
              .replace("{{STYLE_GUIDE}}", style_text)
              .replace("{{TOPIC}}", topic)
              .replace("{{POSTS_DIR}}", blog["posts_dir"])
              .replace("{{TODAY}}", date.today().isoformat())
              .replace("{{CONTEXT}}", search_context(topic))
              .replace("{{EXAMPLE_POST}}", example))

    print(f"[dumalog] writing '{topic}' in {blog_path} via {agent}", file=sys.stderr)
    rc = run(agent_cmd(agent, prompt, autonomous=True), cwd=blog_path).returncode
    if rc == 0:
        record_topic(topic)
    sys.exit(rc)


def cmd_set(a):
    cfg = load_cfg()
    cfg[a.key] = int(a.value) if a.value.isdigit() else a.value
    save_cfg(cfg)
    print(f"[dumalog] {a.key} = {cfg[a.key]}")


def cmd_status(_a):
    cfg = load_cfg()
    for tool in ("mempalace", "hermes", "codex"):
        print(f"{tool:10} {'ok' if shutil.which(tool) else 'MISSING'}")
    for d in SESSION_DIRS:
        print(f"{d}: {'found' if d.is_dir() else 'absent'}")
    print(f"window_hours: {cfg.get('window_hours', DEFAULT_WINDOW_HOURS)}")
    print(json.dumps(cfg, indent=2))


def main():
    p = argparse.ArgumentParser(prog="dumalog", description=__doc__)
    sub = p.add_subparsers(dest="cmd", required=True)

    ab = sub.add_parser("add-blog", help="register a Jekyll blog (git URL or local path)")
    ab.add_argument("repo")
    ab.add_argument("--posts-dir", default="_posts")
    ab.add_argument("--example", help="URL or path of a reference post (default: newest in posts dir)")
    ab.set_defaults(fn=cmd_add_blog)

    w = sub.add_parser("write", help="write a post (no topic = suggest topics from recent activity)")
    w.add_argument("topic", nargs="?", help="post topic; omit to get suggestions")
    w.add_argument("--blog", help="blog name (default: first registered)")
    w.add_argument("--window", type=int,
                   help=f"activity window in hours for suggestions "
                        f"(default: window_hours setting or {DEFAULT_WINDOW_HOURS})")
    w.set_defaults(fn=cmd_write)

    st = sub.add_parser("set", help="set a config value, e.g.: dumalog set window_hours 48")
    st.add_argument("key")
    st.add_argument("value")
    st.set_defaults(fn=cmd_set)

    sub.add_parser("setup", help="find local Jekyll blogs, pick example posts, "
                                 "generate a style guide").set_defaults(fn=cmd_setup)
    sub.add_parser("mine", help="(re)ingest Claude/Codex sessions into memPalace").set_defaults(fn=cmd_mine)
    sub.add_parser("status", help="show tools and config").set_defaults(fn=cmd_status)

    a = p.parse_args()
    a.fn(a)


if __name__ == "__main__":
    main()
